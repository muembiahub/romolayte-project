<%- include('partials/header') %>

<main class="container">
  <section class="services">
    <h1><%= title %></h1>

    <% if (services && services.length > 0) { %>
      <div class="services-grid">
        <% services.forEach(service => { %>
          <div class="service-card">
            <div class="service-image">
              <img 
                src="<%= service.logo || 'https://ofhmwjzxakhgbafywxwp.supabase.co/storage/v1/object/public/services-images/default.webp' %>" 
                alt="<%= service.name %>" 
                onerror="this.onerror=null;this.src='https://ofhmwjzxakhgbafywxwp.supabase.co/storage/v1/object/public/services-images/default.webp';" />
            </div>

            <div class="service-info">
              <h2><%= service.name %></h2>
              <p class="description"><%= service.description %></p>
              <p class="price">
                <% if (service.price) { %>
                  <strong>Prix :</strong> <%= service.price %> $
                <% } else { %>
                  <strong>Prix :</strong> Sur devis
                <% } %>
              </p>
              <p class="category">
                <strong>Catégorie :</strong> <%= service.category_id %>
              </p>
              <a href="/services/details/<%= service.service_id %>" class="btn">Voir détails</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="no-services">Aucun service disponible pour le moment.</p>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>
